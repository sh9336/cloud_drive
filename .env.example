# Server Configuration
SERVER_PORT=8080
ENVIRONMENT=development
SHUTDOWN_TIMEOUT=10s
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=file_storage
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DATABASE_URL= # Production support

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AWS Configuration
AWS_REGION=us-east-1
USE_IAM_ROLE=false
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_ENDPOINT=http://minio:9000
AWS_ENDPOINT_EXTERNAL=http://localhost:9000

# JWT Configuration
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=file-storage-api

# Storage Configuration
S3_BUCKET_NAME=file-storage-bucket
PRESIGNED_URL_EXPIRY=15m
MAX_FILE_SIZE=104857600

JWT_ACCESS_SECRET=your_jwt_refresh_secret_base64
JWT_REFRESH_SECRET=your_jwt_refresh_secret_base64
REDIS_URL= # Production support (Upstash/etc)
